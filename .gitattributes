# normalize line endings so the repo builds the same on Linux/macOS/Windows.
# important for the Docker image, which runs on linux/amd64.
* text=auto eol=lf

*.sh   text eol=lf
*.py   text eol=lf
*.json text eol=lf
*.md   text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf

Dockerfile text eol=lf

# only the production weight ships, via Git LFS
TechPackApp/techpack_generator/models/best_model_v3.pth filter=lfs diff=lfs merge=lfs -text
